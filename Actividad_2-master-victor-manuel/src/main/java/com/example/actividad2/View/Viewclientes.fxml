<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<VBox spacing="10" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.actividad2.Controller.ClientesController">

    <TextField fx:id="txtId" promptText="ID"/>
    <TextField fx:id="txtNombre" promptText="Nombre"/>
    <TextField fx:id="txtTelefono" promptText="Teléfono"/>
    <TextField fx:id="txtDireccion" promptText="Dirección"/>

    <Button text="Registrar Cliente" onAction="#registrarCliente"/>

</VBox>